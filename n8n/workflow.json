              "value": "=New lead processed!\nName: {{ $json.name }}\nEmail: {{ $json.email }}\nCompany: {{ $json.company }}\nIndustry: {{ $json.industry }}\nIntent: {{ $json.intent }} ({{ $json.confidence }})"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
