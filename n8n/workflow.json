{
  "name": "Lead Processing Pipeline",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "incoming-lead",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "lead-webhook-001"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\n\nconst name = body.name || '';\nconst email = body.email || '';\nconst company = body.company || '';\n\nconst errors = [];\n\nif (!name || name.trim().length === 0) {\n  errors.push('name is required');\n}\n\nif (!email || !email.includes('@')) {\n  errors.push('valid email is required');\n}\n\nif (!company || company.trim().length === 0) {\n  errors.push('company is required');\n}\n\nif (errors.length > 0) {\n  return [{ json: { valid: false, errors: errors, name, email, company } }];\n}\n\nreturn [{ json: { valid: true, name: name.trim(), email: email.trim().toLowerCase(), company: company.trim() } }];"
      },
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-valid",
              "leftValue": "={{ $json.valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "check-validation",
      "name": "Is Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/enrich",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "ase-lead-automation-2024"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $json.name }}"
            },
            {
              "name": "email",
              "value": "={{ $json.email }}"
            },
            {
              "name": "company",
              "value": "={{ $json.company }}"
            }
          ]
        },
        "options": {
          "timeout": 15000,
          "retry": {
            "enabled": true,
            "maxRetries": 3,
            "retryInterval": 2000
          }
        }
      },
      "id": "call-enrich-api",
      "name": "Enrich Lead",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [920, 200],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "const input = $('Validate Input').first().json;\nconst enrichment = $input.first().json;\n\nconst message = `Lead from ${input.name} at ${input.company}`;\n\nreturn [{\n  json: {\n    name: input.name,\n    email: input.email,\n    company: input.company,\n    linkedin_url: enrichment.linkedin_url,\n    company_size: enrichment.company_size,\n    industry: enrichment.industry,\n    classify_message: message\n  }\n}];"
      },
      "id": "merge-enrich",
      "name": "Merge Enrichment",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1140, 200]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/classify",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-API-Key",
              "value": "ase-lead-automation-2024"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "message",
              "value": "={{ $json.classify_message }}"
            }
          ]
        },
        "options": {
          "timeout": 30000
        }
      },
      "id": "call-classify-api",
      "name": "Classify Intent",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1360, 200],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 2000
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Merge Enrichment').first().json;\nconst classification = $input.first().json;\n\nconst now = new Date().toISOString();\n\nreturn [{\n  json: {\n    name: lead.name,\n    email: lead.email,\n    company: lead.company,\n    linkedin_url: lead.linkedin_url,\n    company_size: lead.company_size,\n    industry: lead.industry,\n    intent: classification.intent,\n    confidence: classification.confidence,\n    status: 'processed',\n    processed_at: now\n  }\n}];"
      },
      "id": "build-final-record",
      "name": "Build Final Record",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1580, 200]
    },
