# Gemini API key for intent classification
GEMINI_API_KEY=your-gemini-api-key-here

# API key for authenticating requests to this service
API_KEY=ase-lead-automation-2024

# SQLite database path (default works for local dev)
DATABASE_URL=sqlite+aiosqlite:///./leads.db

# Optional: Redis URL for caching enrichment results
REDIS_URL=

# Optional: Webhook URL to send notifications when a lead is processed
NOTIFICATION_WEBHOOK_URL=
